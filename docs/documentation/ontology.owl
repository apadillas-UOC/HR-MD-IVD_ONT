    </owl:Class>
    


    <!-- http://example.org/meddevice#CorrectiveAction -->


    <owl:Class rdf:about="http://example.org/meddevice#CorrectiveAction">
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Field safety corrective action (FSCA) taken as a response to an incident.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">Corrective action</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#CybersecurityRisk -->


    <owl:Class rdf:about="http://example.org/meddevice#CybersecurityRisk">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#RiskType"/>
    </owl:Class>
    


    <!-- http://example.org/meddevice#Device -->


    <owl:Class rdf:about="http://example.org/meddevice#Device">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#RiskType"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/meddevice#manufacturedBy"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Any high-risk medical device or in vitro diagnostic device registered in the EU catalogue.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">Device</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#DeviceFailure -->


    <owl:Class rdf:about="http://example.org/meddevice#DeviceFailure">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#RiskCategory"/>
    </owl:Class>
    


    <!-- http://example.org/meddevice#DevicePerformance -->


    <owl:Class rdf:about="http://example.org/meddevice#DevicePerformance">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#RiskCategory"/>
    </owl:Class>
    


    <!-- http://example.org/meddevice#DeviceSafety -->


    <owl:Class rdf:about="http://example.org/meddevice#DeviceSafety">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#RiskCategory"/>
    </owl:Class>
    


    <!-- http://example.org/meddevice#DiagnosticError -->


    <owl:Class rdf:about="http://example.org/meddevice#DiagnosticError">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#RiskCategory"/>
    </owl:Class>
    


    <!-- http://example.org/meddevice#DiagnosticRisk -->


    <owl:Class rdf:about="http://example.org/meddevice#DiagnosticRisk">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#RiskType"/>
    </owl:Class>
    


    <!-- http://example.org/meddevice#HighRiskDevice -->


    <owl:Class rdf:about="http://example.org/meddevice#HighRiskDevice">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#Device"/>
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Device belonging to the highest risk classes (IIb, III or D).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">High-risk device</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#IVDClass -->


    <owl:Class rdf:about="http://example.org/meddevice#IVDClass">
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Risk class categories defined by the IVDR regulation for in vitro diagnostic devices.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">IVD class (IVDR)</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#ImplantableActiveDevice -->


    <owl:Class rdf:about="http://example.org/meddevice#ImplantableActiveDevice">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#ActiveImplant"/>
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Medical device that is both implantable and active.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">Implantable active device</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#ImplantableDevice -->


    <owl:Class rdf:about="http://example.org/meddevice#ImplantableDevice">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#MedicalDevice"/>
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Medical device intended to be totally or partially introduced into the human body.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">Implantable device</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#InVitroDiagnosticDevice -->


    <owl:Class rdf:about="http://example.org/meddevice#InVitroDiagnosticDevice">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#Device"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/meddevice#hasIVDClass"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Device used to perform in vitro diagnostic tests (IVD).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">In vitro diagnostic device</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#Incident -->


    <owl:Class rdf:about="http://example.org/meddevice#Incident">
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Event reported in association with a device (e.g., adverse event, malfunction).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#InfectionRisk -->


    <owl:Class rdf:about="http://example.org/meddevice#InfectionRisk">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#RiskType"/>
    </owl:Class>
    


