        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Contact email for regulatory matters.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">contact email</rdfs:label>
    </owl:DatatypeProperty>
    


