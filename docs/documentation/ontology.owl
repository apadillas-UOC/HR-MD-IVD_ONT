<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/meddevice#"
     xml:base="http://example.org/meddevice"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:meddevice="http://example.org/meddevice#">
    <owl:Ontology rdf:about="http://example.org/meddevice#">
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <dc:description xml:lang="en">Ontology modelling high-risk medical devices and in vitro diagnostic devices, including manufacturers, risks, incidents and corrective actions, based on MDR/IVDR regulations.</dc:description>
        <dc:title xml:lang="en">High‑Risk Medical Devices and In Vitro Diagnostics Ontology</dc:title>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/elements/1.1/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://www.w3.org/2003/11/swrl#argument1 -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#argument1"/>
    


    <!-- http://www.w3.org/2003/11/swrl#argument2 -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#argument2"/>
    


    <!-- http://www.w3.org/2003/11/swrl#body -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#body"/>
    


    <!-- http://www.w3.org/2003/11/swrl#classPredicate -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#classPredicate"/>
    


    <!-- http://www.w3.org/2003/11/swrl#head -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#head"/>
    


    <!-- http://www.w3.org/2003/11/swrl#propertyPredicate -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#propertyPredicate"/>
    


    <!-- http://www.w3.org/2003/11/swrl#varName -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#varName"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://example.org/meddevice#hasCorrectiveAction -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#hasCorrectiveAction">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#CorrectiveAction"/>
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Relates an incident to the corrective action taken.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">has corrective action</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#hasIVDClass -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#hasIVDClass">
        <rdfs:domain rdf:resource="http://example.org/meddevice#InVitroDiagnosticDevice"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#IVDClass"/>
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Relates an IVD device to its IVDR risk class.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">has IVD class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#hasIncident -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#hasIncident">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Device"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#Incident"/>
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Links a device to an incident reported about it.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">has incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#hasRisk -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#hasRisk">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Device"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#Risk"/>
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Associates a device with a risk identified in the IMDRF catalogue.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">has risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#hasRiskCategory -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#hasRiskCategory">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Risk"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#RiskCategory"/>
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Links a risk to its category.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">has risk category</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#hasRiskClass -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#hasRiskClass">
        <rdfs:domain rdf:resource="http://example.org/meddevice#MedicalDevice"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#RiskClass"/>
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Relates a medical device to its MDR risk class.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">has risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#hasRiskType -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#hasRiskType">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Risk"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#RiskType"/>
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Links a risk to its type.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">has risk type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#manufacturedBy -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#manufacturedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/meddevice#Device"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#Manufacturer"/>
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Links a device to its manufacturer.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">manufactured by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#relatedIncident -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#relatedIncident">
        <rdfs:domain rdf:resource="http://example.org/meddevice#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#Incident"/>
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Links a corrective action to the incident it addresses.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">related incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://example.org/meddevice#actionDate -->


    <owl:DatatypeProperty rdf:about="http://example.org/meddevice#actionDate">
        <rdfs:domain rdf:resource="http://example.org/meddevice#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Date when the corrective action was issued.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">action date</rdfs:label>
    </owl:DatatypeProperty>
    


