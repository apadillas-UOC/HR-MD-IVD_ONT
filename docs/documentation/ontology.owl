        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Description of the corrective action.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">corrective action description</rdfs:label>
    </owl:DatatypeProperty>
    


