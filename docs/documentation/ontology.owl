    <!-- http://example.org/meddevice#ClassIII -->


    <owl:Class rdf:about="http://example.org/meddevice#ClassIII">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#RiskClass"/>
    </owl:Class>
    


    <!-- http://example.org/meddevice#ClassIIa -->


    <owl:Class rdf:about="http://example.org/meddevice#ClassIIa">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#RiskClass"/>
    </owl:Class>
    


    <!-- http://example.org/meddevice#ClassIIb -->


    <owl:Class rdf:about="http://example.org/meddevice#ClassIIb">
