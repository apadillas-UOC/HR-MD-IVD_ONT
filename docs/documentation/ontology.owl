    <!-- http://example.org/meddevice#ActiveDevice -->


    <owl:Class rdf:about="http://example.org/meddevice#ActiveDevice">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#MedicalDevice"/>
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Medical device that relies on a power source for its operation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">Active device</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#ActiveImplant -->


    <owl:Class rdf:about="http://example.org/meddevice#ActiveImplant">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#ImplantableDevice"/>
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Implantable medical device that relies on a power source for operation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">Active implant</rdfs:label>
    </owl:Class>
    


