    </owl:Class>
    


    <!-- http://example.org/meddevice#InterferenceRisk -->


    <owl:Class rdf:about="http://example.org/meddevice#InterferenceRisk">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#RiskType"/>
    </owl:Class>
    


    <!-- http://example.org/meddevice#MalfunctionRisk -->


    <owl:Class rdf:about="http://example.org/meddevice#MalfunctionRisk">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#RiskType"/>
    </owl:Class>
    


    <!-- http://example.org/meddevice#Manufacturer -->


    <owl:Class rdf:about="http://example.org/meddevice#Manufacturer">
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Organization responsible for producing a medical device.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">Manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#MaterialRisk -->


    <owl:Class rdf:about="http://example.org/meddevice#MaterialRisk">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#RiskType"/>
    </owl:Class>
    


    <!-- http://example.org/meddevice#MedicalDevice -->


    <owl:Class rdf:about="http://example.org/meddevice#MedicalDevice">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#Device"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/meddevice#hasRiskClass"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Device intended for use in diagnosis, prevention, monitoring, treatment or alleviation of disease.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">Medical device</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#PatientHarm -->


    <owl:Class rdf:about="http://example.org/meddevice#PatientHarm">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#RiskCategory"/>
    </owl:Class>
    


    <!-- http://example.org/meddevice#ProductQuality -->


    <owl:Class rdf:about="http://example.org/meddevice#ProductQuality">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#RiskCategory"/>
    </owl:Class>
    


    <!-- http://example.org/meddevice#RadiationRisk -->


    <owl:Class rdf:about="http://example.org/meddevice#RadiationRisk">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#RiskType"/>
    </owl:Class>
    


    <!-- http://example.org/meddevice#Risk -->


    <owl:Class rdf:about="http://example.org/meddevice#Risk">
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Potential hazard identified for a device according to the IMDRF nomenclature.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://example.org/meddevice#"/>
        <rdfs:label xml:lang="en">Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#RiskCategory -->


    <owl:Class rdf:about="http://example.org/meddevice#RiskCategory">
        <dc:creator xml:lang="en">apadillas</dc:creator>
        <rdfs:comment xml:lang="en">Category of risk according to IMDRF taxonomy.</rdfs:comment>
