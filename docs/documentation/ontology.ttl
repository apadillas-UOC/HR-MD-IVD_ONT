@prefix : <http://example.org/meddevice#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://example.org/meddevice#> .

<http://example.org/meddevice#> rdf:type owl:Ontology ;
                                 <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                                 <http://purl.org/dc/elements/1.1/description> "Ontology modelling high-risk medical devices and in vitro diagnostic devices, including manufacturers, risks, incidents and corrective actions, based on MDR/IVDR regulations."@en ;
                                 <http://purl.org/dc/elements/1.1/title> "High‑Risk Medical Devices and In Vitro Diagnostics Ontology"@en ;
                                 rdfs:isDefinedBy <http://example.org/meddevice#> .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/creator
<http://purl.org/dc/elements/1.1/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/description
<http://purl.org/dc/elements/1.1/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
<http://purl.org/dc/elements/1.1/title> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/11/swrl#argument1
<http://www.w3.org/2003/11/swrl#argument1> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/11/swrl#argument2
<http://www.w3.org/2003/11/swrl#argument2> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/11/swrl#body
<http://www.w3.org/2003/11/swrl#body> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/11/swrl#classPredicate
<http://www.w3.org/2003/11/swrl#classPredicate> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/11/swrl#head
<http://www.w3.org/2003/11/swrl#head> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/11/swrl#propertyPredicate
<http://www.w3.org/2003/11/swrl#propertyPredicate> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/11/swrl#varName
<http://www.w3.org/2003/11/swrl#varName> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://example.org/meddevice#hasCorrectiveAction
:hasCorrectiveAction rdf:type owl:ObjectProperty ;
                     rdfs:domain :Incident ;
                     rdfs:range :CorrectiveAction ;
                     <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                     rdfs:comment "Relates an incident to the corrective action taken."@en ;
                     rdfs:isDefinedBy <http://example.org/meddevice#> ;
                     rdfs:label "has corrective action"@en .


###  http://example.org/meddevice#hasIVDClass
:hasIVDClass rdf:type owl:ObjectProperty ;
             rdfs:domain :InVitroDiagnosticDevice ;
             rdfs:range :IVDClass ;
             <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
             rdfs:comment "Relates an IVD device to its IVDR risk class."@en ;
             rdfs:isDefinedBy <http://example.org/meddevice#> ;
             rdfs:label "has IVD class"@en .


###  http://example.org/meddevice#hasIncident
:hasIncident rdf:type owl:ObjectProperty ;
             rdfs:domain :Device ;
             rdfs:range :Incident ;
             <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
             rdfs:comment "Links a device to an incident reported about it."@en ;
             rdfs:isDefinedBy <http://example.org/meddevice#> ;
             rdfs:label "has incident"@en .


###  http://example.org/meddevice#hasRisk
:hasRisk rdf:type owl:ObjectProperty ;
         rdfs:domain :Device ;
         rdfs:range :Risk ;
         <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
         rdfs:comment "Associates a device with a risk identified in the IMDRF catalogue."@en ;
         rdfs:isDefinedBy <http://example.org/meddevice#> ;
         rdfs:label "has risk"@en .


###  http://example.org/meddevice#hasRiskCategory
:hasRiskCategory rdf:type owl:ObjectProperty ;
                 rdfs:domain :Risk ;
                 rdfs:range :RiskCategory ;
                 <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                 rdfs:comment "Links a risk to its category."@en ;
                 rdfs:isDefinedBy <http://example.org/meddevice#> ;
                 rdfs:label "has risk category"@en .


###  http://example.org/meddevice#hasRiskClass
:hasRiskClass rdf:type owl:ObjectProperty ;
              rdfs:domain :MedicalDevice ;
              rdfs:range :RiskClass ;
              <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
              rdfs:comment "Relates a medical device to its MDR risk class."@en ;
              rdfs:isDefinedBy <http://example.org/meddevice#> ;
              rdfs:label "has risk class"@en .


###  http://example.org/meddevice#hasRiskType
:hasRiskType rdf:type owl:ObjectProperty ;
             rdfs:domain :Risk ;
             rdfs:range :RiskType ;
             <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
             rdfs:comment "Links a risk to its type."@en ;
             rdfs:isDefinedBy <http://example.org/meddevice#> ;
             rdfs:label "has risk type"@en .


###  http://example.org/meddevice#manufacturedBy
:manufacturedBy rdf:type owl:ObjectProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain :Device ;
                rdfs:range :Manufacturer ;
                <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                rdfs:comment "Links a device to its manufacturer."@en ;
                rdfs:isDefinedBy <http://example.org/meddevice#> ;
                rdfs:label "manufactured by"@en .


###  http://example.org/meddevice#relatedIncident
:relatedIncident rdf:type owl:ObjectProperty ;
                 rdfs:domain :CorrectiveAction ;
                 rdfs:range :Incident ;
                 <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                 rdfs:comment "Links a corrective action to the incident it addresses."@en ;
                 rdfs:isDefinedBy <http://example.org/meddevice#> ;
                 rdfs:label "related incident"@en .


#################################################################
#    Data properties
#################################################################

###  http://example.org/meddevice#actionDate
:actionDate rdf:type owl:DatatypeProperty ;
            rdfs:domain :CorrectiveAction ;
            rdfs:range xsd:date ;
            <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
            rdfs:comment "Date when the corrective action was issued."@en ;
            rdfs:isDefinedBy <http://example.org/meddevice#> ;
            rdfs:label "action date"@en .


###  http://example.org/meddevice#actionScope
:actionScope rdf:type owl:DatatypeProperty ;
             rdfs:domain :CorrectiveAction ;
             rdfs:range xsd:string ;
             <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
             rdfs:comment "Scope of devices affected."@en ;
             rdfs:isDefinedBy <http://example.org/meddevice#> ;
             rdfs:label "scope"@en .


###  http://example.org/meddevice#actionStatus
:actionStatus rdf:type owl:DatatypeProperty ;
              rdfs:domain :CorrectiveAction ;
              rdfs:range xsd:string ;
              <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
              rdfs:comment "Status of the corrective action (Open, Closed)."@en ;
              rdfs:isDefinedBy <http://example.org/meddevice#> ;
              rdfs:label "status"@en .


###  http://example.org/meddevice#authorizationNumber
:authorizationNumber rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Manufacturer ;
                     rdfs:range xsd:string ;
                     <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                     rdfs:comment "Authorization number granted by the competent authority."@en ;
                     rdfs:isDefinedBy <http://example.org/meddevice#> ;
                     rdfs:label "authorization number"@en .


###  http://example.org/meddevice#closureDate
:closureDate rdf:type owl:DatatypeProperty ;
             rdfs:domain :CorrectiveAction ;
             rdfs:range xsd:date ;
             <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
             rdfs:comment "Date when the corrective action was closed."@en ;
             rdfs:isDefinedBy <http://example.org/meddevice#> ;
             rdfs:label "closure date"@en .


###  http://example.org/meddevice#contactEmail
:contactEmail rdf:type owl:DatatypeProperty ;
              rdfs:domain :Manufacturer ;
              rdfs:range xsd:string ;
              <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
              rdfs:comment "Contact email for regulatory matters."@en ;
              rdfs:isDefinedBy <http://example.org/meddevice#> ;
              rdfs:label "contact email"@en .


###  http://example.org/meddevice#correctiveActionDescription
:correctiveActionDescription rdf:type owl:DatatypeProperty ;
                             rdfs:domain :CorrectiveAction ;
                             rdfs:range xsd:string ;
                             <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                             rdfs:comment "Description of the corrective action."@en ;
                             rdfs:isDefinedBy <http://example.org/meddevice#> ;
                             rdfs:label "corrective action description"@en .


###  http://example.org/meddevice#correctiveActionID
:correctiveActionID rdf:type owl:DatatypeProperty ;
                    rdfs:domain :CorrectiveAction ;
                    rdfs:range xsd:string ;
                    <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                    rdfs:comment "Field Safety Corrective Action identifier."@en ;
                    rdfs:isDefinedBy <http://example.org/meddevice#> ;
                    rdfs:label "FSCA ID"@en .


###  http://example.org/meddevice#correctiveActionType
:correctiveActionType rdf:type owl:DatatypeProperty ;
                      rdfs:domain :CorrectiveAction ;
                      rdfs:range xsd:string ;
                      <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                      rdfs:comment "Type of corrective action (SafetyAlert, Recall, etc.)."@en ;
                      rdfs:isDefinedBy <http://example.org/meddevice#> ;
                      rdfs:label "action type"@en .


###  http://example.org/meddevice#countriesAffected
:countriesAffected rdf:type owl:DatatypeProperty ;
                   rdfs:domain :CorrectiveAction ;
                   rdfs:range xsd:string ;
                   <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                   rdfs:comment "Countries affected by the corrective action."@en ;
                   rdfs:isDefinedBy <http://example.org/meddevice#> ;
                   rdfs:label "countries affected"@en .


###  http://example.org/meddevice#countryReported
:countryReported rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Incident ;
                 rdfs:range xsd:string ;
                 <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                 rdfs:comment "Country where the incident was reported."@en ;
                 rdfs:isDefinedBy <http://example.org/meddevice#> ;
                 rdfs:label "country reported"@en .


###  http://example.org/meddevice#detectionDate
:detectionDate rdf:type owl:DatatypeProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:date ;
               <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
               rdfs:comment "Date when the incident was detected."@en ;
               rdfs:isDefinedBy <http://example.org/meddevice#> ;
               rdfs:label "detection date"@en .


###  http://example.org/meddevice#deviceID
:deviceID rdf:type owl:DatatypeProperty ;
          rdfs:domain :Device ;
          rdfs:range xsd:string ;
          <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
          rdfs:comment "Identifier of the device (e.g., catalogue number)."@en ;
          rdfs:isDefinedBy <http://example.org/meddevice#> ;
          rdfs:label "device ID"@en .


###  http://example.org/meddevice#deviceName
:deviceName rdf:type owl:DatatypeProperty ;
            rdfs:domain :Device ;
            rdfs:range xsd:string ;
            <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
            rdfs:comment "Name of the device."@en ;
            rdfs:isDefinedBy <http://example.org/meddevice#> ;
            rdfs:label "device name"@en .


###  http://example.org/meddevice#devicesAffected
:devicesAffected rdf:type owl:DatatypeProperty ;
                 rdfs:domain :CorrectiveAction ;
                 rdfs:range xsd:string ;
                 <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                 rdfs:comment "Number of devices affected."@en ;
                 rdfs:isDefinedBy <http://example.org/meddevice#> ;
                 rdfs:label "devices affected"@en .


###  http://example.org/meddevice#eudamedFscaRef
:eudamedFscaRef rdf:type owl:DatatypeProperty ;
                rdfs:domain :CorrectiveAction ;
                rdfs:range xsd:string ;
                <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                rdfs:comment "EUDAMED reference for the corrective action."@en ;
                rdfs:isDefinedBy <http://example.org/meddevice#> ;
                rdfs:label "EUDAMED FSCA reference"@en .


###  http://example.org/meddevice#eudamedIncidentRef
:eudamedIncidentRef rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Incident ;
                    rdfs:range xsd:string ;
                    <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                    rdfs:comment "EUDAMED reference for the incident."@en ;
                    rdfs:isDefinedBy <http://example.org/meddevice#> ;
                    rdfs:label "EUDAMED incident reference"@en .


###  http://example.org/meddevice#eudamedSRN
:eudamedSRN rdf:type owl:DatatypeProperty ;
            rdfs:domain :Manufacturer ;
            rdfs:range xsd:string ;
            <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
            rdfs:comment "Single Registration Number assigned in EUDAMED."@en ;
            rdfs:isDefinedBy <http://example.org/meddevice#> ;
            rdfs:label "EUDAMED SRN"@en .


###  http://example.org/meddevice#eventDate
:eventDate rdf:type owl:DatatypeProperty ;
           rdfs:domain :Incident ;
           rdfs:range xsd:date ;
           <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
           rdfs:comment "Date when the incident event occurred."@en ;
           rdfs:isDefinedBy <http://example.org/meddevice#> ;
           rdfs:label "event date"@en .


###  http://example.org/meddevice#incidentDescription
:incidentDescription rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Incident ;
                     rdfs:range xsd:string ;
                     <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                     rdfs:comment "Description of the incident."@en ;
                     rdfs:isDefinedBy <http://example.org/meddevice#> ;
                     rdfs:label "incident description"@en .


###  http://example.org/meddevice#incidentID
:incidentID rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:string ;
            <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
            rdfs:comment "Identifier of the incident."@en ;
            rdfs:isDefinedBy <http://example.org/meddevice#> ;
            rdfs:label "incident ID"@en .


###  http://example.org/meddevice#incidentOutcome
:incidentOutcome rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Incident ;
                 rdfs:range xsd:string ;
                 <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                 rdfs:comment "Outcome of the incident."@en ;
                 rdfs:isDefinedBy <http://example.org/meddevice#> ;
                 rdfs:label "incident outcome"@en .


###  http://example.org/meddevice#incidentType
:incidentType rdf:type owl:DatatypeProperty ;
              rdfs:domain :Incident ;
              rdfs:range xsd:string ;
              <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
              rdfs:comment "Type of incident (SeriousIncident, NearMissIncident, etc.)."@en ;
              rdfs:isDefinedBy <http://example.org/meddevice#> ;
              rdfs:label "incident type"@en .


###  http://example.org/meddevice#intendedPurpose
:intendedPurpose rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Device ;
                 rdfs:range xsd:string ;
                 <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                 rdfs:comment "Intended purpose of the device."@en ;
                 rdfs:isDefinedBy <http://example.org/meddevice#> ;
                 rdfs:label "intended purpose"@en .


###  http://example.org/meddevice#isActive
:isActive rdf:type owl:DatatypeProperty ;
          rdfs:domain :Device ;
          rdfs:range xsd:boolean ;
          <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
          rdfs:comment "Indicates whether the device is active."@en ;
          rdfs:isDefinedBy <http://example.org/meddevice#> ;
          rdfs:label "is active"@en .


###  http://example.org/meddevice#isIVD
:isIVD rdf:type owl:DatatypeProperty ;
       rdfs:domain :Device ;
       rdfs:range xsd:boolean ;
       <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
       rdfs:comment "Indicates whether the device is an in vitro diagnostic device."@en ;
       rdfs:isDefinedBy <http://example.org/meddevice#> ;
       rdfs:label "is IVD"@en .


###  http://example.org/meddevice#isImplantable
:isImplantable rdf:type owl:DatatypeProperty ;
               rdfs:domain :Device ;
               rdfs:range xsd:boolean ;
               <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
               rdfs:comment "Indicates whether the device is implantable."@en ;
               rdfs:isDefinedBy <http://example.org/meddevice#> ;
               rdfs:label "is implantable"@en .


###  http://example.org/meddevice#isReusable
:isReusable rdf:type owl:DatatypeProperty ;
            rdfs:domain :Device ;
            rdfs:range xsd:boolean ;
            <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
            rdfs:comment "Indicates whether the device is reusable."@en ;
            rdfs:isDefinedBy <http://example.org/meddevice#> ;
            rdfs:label "is reusable"@en .


###  http://example.org/meddevice#manufacturerCountry
:manufacturerCountry rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Manufacturer ;
                     rdfs:range xsd:string ;
                     <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                     rdfs:comment "Country where the manufacturer is located."@en ;
                     rdfs:isDefinedBy <http://example.org/meddevice#> ;
                     rdfs:label "manufacturer country"@en .


###  http://example.org/meddevice#manufacturerName
:manufacturerName rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Manufacturer ;
                  rdfs:range xsd:string ;
                  <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                  rdfs:comment "Legal name of the manufacturer."@en ;
                  rdfs:isDefinedBy <http://example.org/meddevice#> ;
                  rdfs:label "manufacturer name"@en .


###  http://example.org/meddevice#patientAge
:patientAge rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:string ;
            <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
            rdfs:comment "Age of patient involved (if applicable)."@en ;
            rdfs:isDefinedBy <http://example.org/meddevice#> ;
            rdfs:label "patient age"@en .


###  http://example.org/meddevice#patientSex
:patientSex rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:string ;
            <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
            rdfs:comment "Sex of patient involved (if applicable)."@en ;
            rdfs:isDefinedBy <http://example.org/meddevice#> ;
            rdfs:label "patient sex"@en .


###  http://example.org/meddevice#regulatoryFramework
:regulatoryFramework rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Device ;
                     rdfs:range xsd:string ;
                     <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                     rdfs:comment "Regulatory framework (MDR or IVDR) under which the device is classified."@en ;
                     rdfs:isDefinedBy <http://example.org/meddevice#> ;
                     rdfs:label "regulatory framework"@en .


###  http://example.org/meddevice#reportDate
:reportDate rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:date ;
            <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
            rdfs:comment "Date when the incident was reported."@en ;
            rdfs:isDefinedBy <http://example.org/meddevice#> ;
            rdfs:label "report date"@en .


###  http://example.org/meddevice#riskCode
:riskCode rdf:type owl:DatatypeProperty ;
          rdfs:domain :Risk ;
          rdfs:range xsd:string ;
          <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
          rdfs:comment "IMDRF risk code."@en ;
          rdfs:isDefinedBy <http://example.org/meddevice#> ;
          rdfs:label "risk code"@en .


###  http://example.org/meddevice#riskDescription
:riskDescription rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Risk ;
                 rdfs:range xsd:string ;
                 <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                 rdfs:comment "Textual description of the risk."@en ;
                 rdfs:isDefinedBy <http://example.org/meddevice#> ;
                 rdfs:label "risk description"@en .


###  http://example.org/meddevice#riskName
:riskName rdf:type owl:DatatypeProperty ;
          rdfs:domain :Risk ;
          rdfs:range xsd:string ;
          <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
          rdfs:comment "Name of the risk."@en ;
          rdfs:isDefinedBy <http://example.org/meddevice#> ;
          rdfs:label "risk name"@en .


###  http://example.org/meddevice#riskProbability
:riskProbability rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Risk ;
                 rdfs:range xsd:string ;
                 <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                 rdfs:comment "Qualitative probability level (Low, Medium, High)."@en ;
                 rdfs:isDefinedBy <http://example.org/meddevice#> ;
                 rdfs:label "risk probability"@en .


###  http://example.org/meddevice#riskSeverity
:riskSeverity rdf:type owl:DatatypeProperty ;
              rdfs:domain :Risk ;
              rdfs:range xsd:string ;
              <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
              rdfs:comment "Qualitative severity level (Critical, Serious, Moderate)."@en ;
              rdfs:isDefinedBy <http://example.org/meddevice#> ;
              rdfs:label "risk severity"@en .


###  http://example.org/meddevice#udiDI
:udiDI rdf:type owl:DatatypeProperty ;
       rdfs:domain :Device ;
       rdfs:range xsd:string ;
       <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
       rdfs:comment "Unique Device Identification Device Identifier."@en ;
       rdfs:isDefinedBy <http://example.org/meddevice#> ;
       rdfs:label "UDI-DI"@en .


#################################################################
#    Classes
#################################################################

###  http://example.org/meddevice#ActiveDevice
:ActiveDevice rdf:type owl:Class ;
              rdfs:subClassOf :MedicalDevice ;
              <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
              rdfs:comment "Medical device that relies on a power source for its operation."@en ;
              rdfs:isDefinedBy <http://example.org/meddevice#> ;
              rdfs:label "Active device"@en .


###  http://example.org/meddevice#ActiveImplant
:ActiveImplant rdf:type owl:Class ;
               rdfs:subClassOf :ImplantableDevice ;
               <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
               rdfs:comment "Implantable medical device that relies on a power source for operation."@en ;
               rdfs:isDefinedBy <http://example.org/meddevice#> ;
               rdfs:label "Active implant"@en .


###  http://example.org/meddevice#ClassA
:ClassA rdf:type owl:Class ;
        rdfs:subClassOf :IVDClass ;
        <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
        rdfs:comment "IVDR risk class A."@en ;
        rdfs:isDefinedBy <http://example.org/meddevice#> ;
        rdfs:label "Class A"@en .


###  http://example.org/meddevice#ClassB
:ClassB rdf:type owl:Class ;
        rdfs:subClassOf :IVDClass ;
        <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
        rdfs:comment "IVDR risk class B."@en ;
        rdfs:isDefinedBy <http://example.org/meddevice#> ;
        rdfs:label "Class B"@en .


###  http://example.org/meddevice#ClassC
:ClassC rdf:type owl:Class ;
        rdfs:subClassOf :IVDClass .


###  http://example.org/meddevice#ClassD
:ClassD rdf:type owl:Class ;
        rdfs:subClassOf :IVDClass .


###  http://example.org/meddevice#ClassI
:ClassI rdf:type owl:Class ;
        rdfs:subClassOf :RiskClass ;
        <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
        rdfs:comment "MDR risk class I."@en ;
        rdfs:isDefinedBy <http://example.org/meddevice#> ;
        rdfs:label "Class I"@en .


###  http://example.org/meddevice#ClassIII
:ClassIII rdf:type owl:Class ;
          rdfs:subClassOf :RiskClass .


###  http://example.org/meddevice#ClassIIa
:ClassIIa rdf:type owl:Class ;
          rdfs:subClassOf :RiskClass .


###  http://example.org/meddevice#ClassIIb
:ClassIIb rdf:type owl:Class ;
          rdfs:subClassOf :RiskClass .


###  http://example.org/meddevice#ContaminationRisk
:ContaminationRisk rdf:type owl:Class ;
                   rdfs:subClassOf :RiskType .


###  http://example.org/meddevice#CorrectiveAction
:CorrectiveAction rdf:type owl:Class ;
                  <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                  rdfs:comment "Field safety corrective action (FSCA) taken as a response to an incident."@en ;
                  rdfs:isDefinedBy <http://example.org/meddevice#> ;
                  rdfs:label "Corrective action"@en .


###  http://example.org/meddevice#CybersecurityRisk
:CybersecurityRisk rdf:type owl:Class ;
                   rdfs:subClassOf :RiskType .


###  http://example.org/meddevice#Device
:Device rdf:type owl:Class ;
        rdfs:subClassOf :RiskType ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :manufacturedBy ;
                          owl:cardinality "1"^^xsd:nonNegativeInteger
                        ] ;
        <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
        rdfs:comment "Any high-risk medical device or in vitro diagnostic device registered in the EU catalogue."@en ;
        rdfs:isDefinedBy <http://example.org/meddevice#> ;
        rdfs:label "Device"@en .


###  http://example.org/meddevice#DeviceFailure
:DeviceFailure rdf:type owl:Class ;
               rdfs:subClassOf :RiskCategory .


###  http://example.org/meddevice#DevicePerformance
:DevicePerformance rdf:type owl:Class ;
                   rdfs:subClassOf :RiskCategory .


###  http://example.org/meddevice#DeviceSafety
:DeviceSafety rdf:type owl:Class ;
              rdfs:subClassOf :RiskCategory .


###  http://example.org/meddevice#DiagnosticError
:DiagnosticError rdf:type owl:Class ;
                 rdfs:subClassOf :RiskCategory .


###  http://example.org/meddevice#DiagnosticRisk
:DiagnosticRisk rdf:type owl:Class ;
                rdfs:subClassOf :RiskType .


###  http://example.org/meddevice#HighRiskDevice
:HighRiskDevice rdf:type owl:Class ;
                rdfs:subClassOf :Device ;
                <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                rdfs:comment "Device belonging to the highest risk classes (IIb, III or D)."@en ;
                rdfs:isDefinedBy <http://example.org/meddevice#> ;
                rdfs:label "High-risk device"@en .


###  http://example.org/meddevice#IVDClass
:IVDClass rdf:type owl:Class ;
          <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
          rdfs:comment "Risk class categories defined by the IVDR regulation for in vitro diagnostic devices."@en ;
          rdfs:isDefinedBy <http://example.org/meddevice#> ;
          rdfs:label "IVD class (IVDR)"@en .


###  http://example.org/meddevice#ImplantableActiveDevice
:ImplantableActiveDevice rdf:type owl:Class ;
                         rdfs:subClassOf :ActiveImplant ;
                         <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                         rdfs:comment "Medical device that is both implantable and active."@en ;
                         rdfs:isDefinedBy <http://example.org/meddevice#> ;
                         rdfs:label "Implantable active device"@en .


###  http://example.org/meddevice#ImplantableDevice
:ImplantableDevice rdf:type owl:Class ;
                   rdfs:subClassOf :MedicalDevice ;
                   <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                   rdfs:comment "Medical device intended to be totally or partially introduced into the human body."@en ;
                   rdfs:isDefinedBy <http://example.org/meddevice#> ;
                   rdfs:label "Implantable device"@en .


###  http://example.org/meddevice#InVitroDiagnosticDevice
:InVitroDiagnosticDevice rdf:type owl:Class ;
                         rdfs:subClassOf :Device ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty :hasIVDClass ;
                                           owl:cardinality "1"^^xsd:nonNegativeInteger
                                         ] ;
                         <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                         rdfs:comment "Device used to perform in vitro diagnostic tests (IVD)."@en ;
                         rdfs:isDefinedBy <http://example.org/meddevice#> ;
                         rdfs:label "In vitro diagnostic device"@en .


###  http://example.org/meddevice#Incident
:Incident rdf:type owl:Class ;
          <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
          rdfs:comment "Event reported in association with a device (e.g., adverse event, malfunction)."@en ;
          rdfs:isDefinedBy <http://example.org/meddevice#> ;
          rdfs:label "Incident"@en .


###  http://example.org/meddevice#InfectionRisk
:InfectionRisk rdf:type owl:Class ;
               rdfs:subClassOf :RiskType .


###  http://example.org/meddevice#InjuryRisk
:InjuryRisk rdf:type owl:Class ;
            rdfs:subClassOf :RiskType .


###  http://example.org/meddevice#InterferenceRisk
:InterferenceRisk rdf:type owl:Class ;
                  rdfs:subClassOf :RiskType .


###  http://example.org/meddevice#MalfunctionRisk
:MalfunctionRisk rdf:type owl:Class ;
                 rdfs:subClassOf :RiskType .


###  http://example.org/meddevice#Manufacturer
:Manufacturer rdf:type owl:Class ;
              <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
              rdfs:comment "Organization responsible for producing a medical device."@en ;
              rdfs:isDefinedBy <http://example.org/meddevice#> ;
              rdfs:label "Manufacturer"@en .


###  http://example.org/meddevice#MaterialRisk
:MaterialRisk rdf:type owl:Class ;
              rdfs:subClassOf :RiskType .


###  http://example.org/meddevice#MedicalDevice
:MedicalDevice rdf:type owl:Class ;
               rdfs:subClassOf :Device ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasRiskClass ;
                                 owl:minCardinality "1"^^xsd:nonNegativeInteger
                               ] ;
               <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
               rdfs:comment "Device intended for use in diagnosis, prevention, monitoring, treatment or alleviation of disease."@en ;
               rdfs:isDefinedBy <http://example.org/meddevice#> ;
               rdfs:label "Medical device"@en .


###  http://example.org/meddevice#PatientHarm
:PatientHarm rdf:type owl:Class ;
             rdfs:subClassOf :RiskCategory .


###  http://example.org/meddevice#ProductQuality
:ProductQuality rdf:type owl:Class ;
                rdfs:subClassOf :RiskCategory .


###  http://example.org/meddevice#RadiationRisk
:RadiationRisk rdf:type owl:Class ;
               rdfs:subClassOf :RiskType .


###  http://example.org/meddevice#Risk
:Risk rdf:type owl:Class ;
      <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
      rdfs:comment "Potential hazard identified for a device according to the IMDRF nomenclature."@en ;
      rdfs:isDefinedBy <http://example.org/meddevice#> ;
      rdfs:label "Risk"@en .


###  http://example.org/meddevice#RiskCategory
:RiskCategory rdf:type owl:Class ;
              <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
              rdfs:comment "Category of risk according to IMDRF taxonomy."@en ;
              rdfs:isDefinedBy <http://example.org/meddevice#> ;
              rdfs:label "Risk category"@en .


###  http://example.org/meddevice#RiskClass
:RiskClass rdf:type owl:Class ;
           <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
           rdfs:comment "Risk class categories defined by the MDR regulation."@en ;
           rdfs:isDefinedBy <http://example.org/meddevice#> ;
           rdfs:label "Risk class (MDR)"@en .


###  http://example.org/meddevice#RiskType
:RiskType rdf:type owl:Class ;
          <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
          rdfs:comment "More specific risk classification (e.g., MalfunctionRisk, InjuryRisk)."@en ;
          rdfs:isDefinedBy <http://example.org/meddevice#> ;
          rdfs:label "Risk type"@en .


###  http://example.org/meddevice#SelfTestDevice
:SelfTestDevice rdf:type owl:Class ;
                rdfs:subClassOf :InVitroDiagnosticDevice ;
                <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                rdfs:comment "Device used by patients for self-monitoring."@en ;
                rdfs:isDefinedBy <http://example.org/meddevice#> ;
                rdfs:label "Self-test device"@en .


###  http://example.org/meddevice#SingleUseDevice
:SingleUseDevice rdf:type owl:Class ;
                 rdfs:subClassOf :MedicalDevice ;
                 <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                 rdfs:comment "Medical device intended for single use."@en ;
                 rdfs:isDefinedBy <http://example.org/meddevice#> ;
                 rdfs:label "Single-use device"@en .


###  http://example.org/meddevice#SoftwareRisk
:SoftwareRisk rdf:type owl:Class ;
              rdfs:subClassOf :RiskType .


###  http://example.org/meddevice#UnderCorrectiveAction
:UnderCorrectiveAction rdf:type owl:Class ;
                       rdfs:subClassOf :Device ;
                       <http://purl.org/dc/elements/1.1/creator> "apadillas"@en ;
                       rdfs:comment "Device for which a corrective action is ongoing."@en ;
                       rdfs:isDefinedBy <http://example.org/meddevice#> ;
                       rdfs:label "Device under corrective action"@en .


